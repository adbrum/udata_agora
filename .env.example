# =============================================================================
# dados.gov.pt - Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust values for your environment.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Backend API
# Relative URLs — client-side fetches go through the Next.js rewrite proxy
NEXT_PUBLIC_API_BASE=/api/1
NEXT_PUBLIC_API_V2_BASE=/api/2
# Absolute backend URL used by next.config.ts rewrites (server-side only)
BACKEND_URL=http://localhost:7000
NEXT_PUBLIC_FRONT_BASE=http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://dados.gov.pt/
NEXT_PUBLIC_STATIC_URL=https://static.data.gouv.fr/static/

# Feature flags
NEXT_PUBLIC_READ_ONLY_MODE=false
NEXT_PUBLIC_REQUIRE_EMAIL_CONFIRMATION=true
# Set to true to show the Autenticação.gov (SAML) login button
NEXT_PUBLIC_SAML_ENABLED=true

# Analytics (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_MATOMO_HOST=
NEXT_PUBLIC_MATOMO_SITE_ID=1
